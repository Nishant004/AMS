@model List<AMS.Models.ViewModel.EmployeeQuotaDisplayVM>

@if (!Model.Any())
{
    <div class="alert alert-info">No holiday quotas found for the selected year.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-light">
            <tr>
                <th>Employee ID</th>
                <th>Name</th>
                <th>Year</th>
                <th>Total Holidays</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EmployeeID</td>
                    <td>@item.FullName</td>
                    <td>@item.Year</td>
                    <td>@item.TotalHolidays</td>
                </tr>
            }
        </tbody>
    </table>
}


